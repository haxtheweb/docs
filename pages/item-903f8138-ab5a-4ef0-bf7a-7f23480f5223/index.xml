<content><![CDATA[
<p>Image gallery is a flexible container for displaying images in grid, masonry, or gallery layouts with lightbox support.</p>
<h2 id="header-image-gallery-example">Gallery option</h2>
<image-gallery mode="gallery" accent-color="grey" active-index="0"><img src="https://picsum.photos/400/300" alt="Sample image 1"><img src="https://picsum.photos/400/500" alt="Sample image 2"><img src="https://picsum.photos/400/400" alt="Sample image 3"></image-gallery>
<h2 id="header-image-gallery-example">Grid option</h2>
<image-gallery accent-color="grey" mode="grid" active-index="0" _hax-state="">  <img src="https://picsum.photos/400/300" alt="Sample image 1">
  <img src="https://picsum.photos/400/500" alt="Sample image 2">
  <img src="https://picsum.photos/400/400" alt="Sample image 3">
</image-gallery>
<h2 id="header-image-gallery-example">Masonry option</h2>
<image-gallery accent-color="grey" mode="masonry" active-index="0" _hax-state="">    <img src="https://picsum.photos/400/300" alt="Sample image 1">

    <img src="https://picsum.photos/400/500" alt="Sample image 2">

    <img src="https://picsum.photos/400/400" alt="Sample image 3">

</image-gallery>
]]></content>
